generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DEVELOPER
  COMPLIANCE_OFFICER
  ENGINEERING_MANAGER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  name          String
  passwordHash  String?
  role          Role     @default(DEVELOPER)
  avatarUrl     String?

  // Google OAuth
  googleId      String?  @unique
  googleEmail   String?

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Refresh tokens (one-to-many for multi-device support)
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}
